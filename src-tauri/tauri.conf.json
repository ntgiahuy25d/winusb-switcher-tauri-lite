{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WinUSB Switcher Lite",
  "version": "1.0.6",
  "identifier": "com.winusbswitcher.lite",
  "build": {
    "frontendDist": "../out/renderer",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "node scripts/stage-jlink-for-build.mjs && yarn dev",
    "beforeBuildCommand": "yarn build && node scripts/stage-jlink-for-build.mjs"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "WinUSB Switcher Lite",
        "width": 770,
        "height": 530,
        "minWidth": 500,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/_bundle_manifest.txt",
      "resources/jlink/**/*.zip"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}